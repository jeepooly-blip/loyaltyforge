generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Some managed Postgres providers (Vercel Postgres, Neon, Supabase) give you
  // a pooled connection string for the app and a separate direct connection
  // string for migrations. If yours does, uncomment the line below and set
  // DIRECT_URL in your environment.
  // directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Auth / Tenancy
// ---------------------------------------------------------------------------

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String?
  createdAt    DateTime     @default(now())
  memberships  Membership[]
}

model Organization {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  createdAt   DateTime         @default(now())
  memberships Membership[]
  programs    LoyaltyProgram[]
  customers   Customer[]
  apiKeys     ApiKey[]
  transactions Transaction[]
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

model Membership {
  id             String       @id @default(cuid())
  role           Role         @default(STAFF)
  userId         String
  organizationId String
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

// ---------------------------------------------------------------------------
// Loyalty Programs
// ---------------------------------------------------------------------------

enum ProgramType {
  STAMP
  POINTS
  TIERED
}

enum ProgramStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model LoyaltyProgram {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  type           ProgramType
  status         ProgramStatus  @default(DRAFT)
  // Rules: shape depends on `type`. e.g. STAMP -> { stampsRequired, rewardDescription, minSpend, expiresAfterDays }
  //        POINTS -> { pointsPerDollar, pointsForReward, rewardDescription, minSpend, expiresAfterDays }
  //        TIERED -> { tiers: [{ name, threshold, perks }] }
  rules          String         // JSON string (SQLite has no native JSON type)
  // Branding: { logoUrl, primaryColor, terms }
  branding       String         // JSON string
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  cards          LoyaltyCard[]
  transactions   Transaction[]

  @@index([organizationId])
}

model Customer {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  externalId     String?       // used by POS / website integrations
  name           String?
  email          String?
  phone          String?
  createdAt      DateTime      @default(now())
  cards          LoyaltyCard[]
  transactions   Transaction[]

  @@unique([organizationId, externalId])
  @@index([organizationId])
}

model LoyaltyCard {
  id         String         @id @default(cuid())
  customerId String
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  programId  String
  program    LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  balance    Int            @default(0) // stamps or points, depending on program type
  tier       String?        // current tier name, for TIERED programs
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([customerId, programId])
}

enum TransactionType {
  ENROLL
  EARN
  REDEEM
  ADJUST_ADD
  ADJUST_REMOVE
}

model Transaction {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  programId      String
  program        LoyaltyProgram  @relation(fields: [programId], references: [id], onDelete: Cascade)
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type           TransactionType
  amount         Int             // positive delta for earn/adjust_add, negative for redeem/adjust_remove
  reason         String?         // required for manual staff adjustments (audit trail)
  metadata       String?         // JSON string, e.g. { source: "api", orderId: "..." }
  createdAt      DateTime        @default(now())

  @@index([organizationId])
  @@index([programId])
  @@index([customerId])
}

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  prefix         String       // first chars shown in UI, e.g. lf_live_ab12
  hashedKey      String       @unique
  createdAt      DateTime     @default(now())
  lastUsedAt     DateTime?
  revoked        Boolean      @default(false)

  @@index([organizationId])
}
